{
  "name": "event-yangu",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "db:setup": "call scripts\\setup-supabase.bat",
    "db:setup:cloud": "call scripts\\setup-cloud.bat",
    "db:setup:manual": "npx supabase start && timeout /t 15 /nobreak && npx supabase db reset --linked=false && npx supabase db seed && npx supabase gen types typescript --local > src/lib/database.types.ts",
    "db:reset": "npx supabase db reset",
    "db:seed": "npx supabase db seed",
    "db:push": "npx supabase db push",
    "db:types": "npx supabase gen types typescript --local > src/lib/database.types.ts",
    "db:types:cloud": "npx supabase gen types typescript --linked > src/lib/database.types.ts",
    "db:status": "npx supabase status",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:link": "npx supabase link",
    "functions:deploy": "npx supabase functions deploy"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/stack": "^6.3.29",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.13.5",
    "expo": "~51.0.0",
    "expo-secure-store": "~13.0.2",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-url-polyfill": "^2.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@types/react": "~18.2.79",
    "supabase": "^1.142.2",
    "typescript": "~5.3.3"
  },
  "private": true
}
